<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark theme palette. Same keys as Theme.Light.xaml. -->
    <SolidColorBrush x:Key="Brush.Window"           Color="#FF1E1E22" />
    <SolidColorBrush x:Key="Brush.Surface"          Color="#FF26262B" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"       Color="#FF2D2D34" />
    <SolidColorBrush x:Key="Brush.Foreground"       Color="#FFE8E8EA" />
    <SolidColorBrush x:Key="Brush.SubtleForeground" Color="#FFB2B2BA" />
    <SolidColorBrush x:Key="Brush.FaintForeground"  Color="#FF8A8A94" />
    <SolidColorBrush x:Key="Brush.Control"          Color="#FF2A2A30" />
    <SolidColorBrush x:Key="Brush.ControlHover"     Color="#FF34343C" />
    <SolidColorBrush x:Key="Brush.ControlBorder"    Color="#FF3C3C44" />
    <SolidColorBrush x:Key="Brush.Border"           Color="#FF3A3A42" />
    <SolidColorBrush x:Key="Brush.Selection"        Color="#FF3B4160" />
    <SolidColorBrush x:Key="Brush.Accent"           Color="#FF7C6BFF" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Error"            Color="#FFFF6B5E" />
</ResourceDictionary>
