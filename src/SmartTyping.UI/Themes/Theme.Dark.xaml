<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark theme palette. Same keys as Theme.Light.xaml. -->
    <SolidColorBrush x:Key="Brush.Window"           Color="#FF1B1B20" />
    <SolidColorBrush x:Key="Brush.Surface"          Color="#FF232329" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"       Color="#FF2B2B36" />
    <SolidColorBrush x:Key="Brush.Foreground"       Color="#FFECECEF" />
    <SolidColorBrush x:Key="Brush.SubtleForeground" Color="#FFA8A8B2" />
    <SolidColorBrush x:Key="Brush.FaintForeground"  Color="#FF7E7E88" />
    <SolidColorBrush x:Key="Brush.Control"          Color="#FF26262E" />
    <SolidColorBrush x:Key="Brush.ControlHover"     Color="#FF313139" />
    <SolidColorBrush x:Key="Brush.ControlBorder"    Color="#FF3A3A45" />
    <SolidColorBrush x:Key="Brush.Border"           Color="#FF33333D" />
    <SolidColorBrush x:Key="Brush.Selection"        Color="#FF35356088" />
    <SolidColorBrush x:Key="Brush.Accent"           Color="#FF8B7CFF" />
    <SolidColorBrush x:Key="Brush.AccentHover"      Color="#FF9B8CFF" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Error"            Color="#FFFF6B5E" />
</ResourceDictionary>
