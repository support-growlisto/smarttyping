<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light theme palette. Keys are shared with Theme.Dark.xaml; only the values differ. -->
    <SolidColorBrush x:Key="Brush.Window"           Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Surface"          Color="#FFF4F4F8" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"       Color="#FFF1F0FB" />
    <SolidColorBrush x:Key="Brush.Foreground"       Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="Brush.SubtleForeground" Color="#FF666666" />
    <SolidColorBrush x:Key="Brush.FaintForeground"  Color="#FF999999" />
    <SolidColorBrush x:Key="Brush.Control"          Color="#FFF7F7F9" />
    <SolidColorBrush x:Key="Brush.ControlHover"     Color="#FFEAEAF0" />
    <SolidColorBrush x:Key="Brush.ControlBorder"    Color="#FFCCCCCC" />
    <SolidColorBrush x:Key="Brush.Border"           Color="#FFDDDDDD" />
    <SolidColorBrush x:Key="Brush.Selection"        Color="#FFD8E2FF" />
    <SolidColorBrush x:Key="Brush.Accent"           Color="#FF635BFF" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.Error"            Color="#FFC0392B" />
</ResourceDictionary>
