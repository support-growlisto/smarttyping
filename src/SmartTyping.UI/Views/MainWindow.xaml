<Window x:Class="SmartTyping.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:SmartTyping.UI.Localization"
        Title="SmartTyping" Height="560" Width="880"
        MinHeight="500" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Surface}"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" Margin="2,0,2,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="38" Height="38" CornerRadius="10" Background="{DynamicResource Brush.Accent}"
                        VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="20" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="SmartTyping" FontSize="18" FontWeight="Bold" />
                    <TextBlock Foreground="{DynamicResource Brush.SubtleForeground}" FontSize="12" Margin="0,1,0,0"
                               Text="{Binding [Main_Tagline], Source={x:Static loc:LocalizationManager.Instance}}" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ============ Body: sidebar card + content card ============ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="212" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                <DockPanel Margin="12,14,12,12">
                    <Grid DockPanel.Dock="Top" Margin="4,0,0,8">
                        <TextBlock Style="{StaticResource SectionHeader}" VerticalAlignment="Center"
                                   Text="{Binding [Main_Categories], Source={x:Static loc:LocalizationManager.Instance}}" />
                        <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Padding="8,2" FontSize="11"
                                Command="{Binding ManageCategoriesCommand}"
                                Content="{Binding [Main_ManageCategories], Source={x:Static loc:LocalizationManager.Instance}}" />
                    </Grid>

                    <!-- Bottom action grid -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Border Height="1" Background="{DynamicResource Brush.Border}" Margin="0,0,0,10" />
                        <UniformGrid Columns="2" Rows="2">
                            <Button Command="{Binding ImportCommand}" Style="{StaticResource GhostButton}" Margin="0,0,3,3"
                                    Content="{Binding [Main_Import], Source={x:Static loc:LocalizationManager.Instance}}" />
                            <Button Command="{Binding ExportCommand}" Style="{StaticResource GhostButton}" Margin="3,0,0,3"
                                    Content="{Binding [Main_Export], Source={x:Static loc:LocalizationManager.Instance}}" />
                            <Button Command="{Binding StatsCommand}" Style="{StaticResource GhostButton}" Margin="0,3,3,0"
                                    Content="{Binding [Main_Stats], Source={x:Static loc:LocalizationManager.Instance}}" />
                            <Button Click="OnSettingsClick" Style="{StaticResource GhostButton}" Margin="3,3,0,0"
                                    Content="{Binding [Main_Settings], Source={x:Static loc:LocalizationManager.Instance}}" />
                        </UniformGrid>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding CategoryFilters}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             DisplayMemberPath="Name"
                             ItemContainerStyle="{StaticResource NavItem}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </DockPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel Margin="16,14,16,12">
                    <!-- Toolbar -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Search field with a leading glyph -->
                        <Border Grid.Column="0" CornerRadius="8" Background="{DynamicResource Brush.Control}"
                                BorderBrush="{DynamicResource Brush.ControlBorder}" BorderThickness="1" MaxWidth="420"
                                HorizontalAlignment="Stretch">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="🔍" FontSize="13" Margin="10,0,4,0"
                                           VerticalAlignment="Center" Foreground="{DynamicResource Brush.FaintForeground}" />
                                <TextBox BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="{Binding [Main_SearchTooltip], Source={x:Static loc:LocalizationManager.Instance}}" />
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Command="{Binding AddCommand}" Style="{StaticResource AccentButton}"
                                    Content="{Binding [Main_Add], Source={x:Static loc:LocalizationManager.Instance}}" />
                            <Button Command="{Binding EditCommand}" Margin="8,0,0,0"
                                    Content="{Binding [Main_Edit], Source={x:Static loc:LocalizationManager.Instance}}" />
                            <Button Command="{Binding DeleteCommand}" Margin="8,0,0,0"
                                    Content="{Binding [Main_Delete], Source={x:Static loc:LocalizationManager.Instance}}" />
                        </StackPanel>
                    </Grid>

                    <!-- Snippet grid -->
                    <Grid>
                        <DataGrid ItemsSource="{Binding Snippets}"
                                  SelectedItem="{Binding SelectedSnippet, Mode=TwoWay}"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  IsReadOnly="False" HeadersVisibility="Column"
                                  Background="Transparent" RowHeight="40"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="48"
                                                        Header="{Binding [Main_Col_On], Source={x:Static loc:LocalizationManager.Instance}}" />
                                <DataGridTemplateColumn Width="150" IsReadOnly="True"
                                                        Header="{Binding [Main_Col_Trigger], Source={x:Static loc:LocalizationManager.Instance}}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource TriggerChip}">
                                                <TextBlock Text="{Binding Trigger}" FontFamily="Cascadia Code, Consolas, monospace"
                                                           FontSize="12" Foreground="{DynamicResource Brush.Accent}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding ContentPreview}" Width="*" IsReadOnly="True"
                                                    Header="{Binding [Main_Col_Content], Source={x:Static loc:LocalizationManager.Instance}}" />
                                <DataGridTextColumn Binding="{Binding UsageCount}" Width="60" IsReadOnly="True"
                                                    Header="{Binding [Main_Col_Uses], Source={x:Static loc:LocalizationManager.Instance}}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Empty-state hint shown when there are no snippets yet. -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}"
                                    IsHitTestVisible="False">
                            <TextBlock Text="✨" FontSize="34" HorizontalAlignment="Center" Margin="0,0,0,8"
                                       Foreground="{DynamicResource Brush.FaintForeground}" />
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.SubtleForeground}" HorizontalAlignment="Center"
                                       Text="{Binding [Main_Empty_Title], Source={x:Static loc:LocalizationManager.Instance}}" />
                            <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.FaintForeground}" HorizontalAlignment="Center" TextAlignment="Center"
                                       Text="{Binding [Main_Empty_Hint], Source={x:Static loc:LocalizationManager.Instance}}" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ============ Status bar ============ -->
        <Grid Grid.Row="2" Margin="4,10,4,0">
            <TextBlock Foreground="{DynamicResource Brush.SubtleForeground}" FontSize="12"
                       VerticalAlignment="Center" Text="{Binding StatusMessage}" />
        </Grid>
    </Grid>
</Window>
