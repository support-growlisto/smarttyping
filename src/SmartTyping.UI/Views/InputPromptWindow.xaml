<Window x:Class="SmartTyping.UI.Views.InputPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:SmartTyping.UI.Localization"
        Width="340" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" FontFamily="Segoe UI" FontSize="13">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptLabel" Margin="0,0,0,6" TextWrapping="Wrap" />
        <TextBox x:Name="Input" Padding="5,4" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="88" Margin="0,0,8,0" IsCancel="True" Click="OnCancel"
                    Content="{Binding [Edit_Cancel], Source={x:Static loc:LocalizationManager.Instance}}" />
            <Button Width="88" IsDefault="True" Click="OnOk"
                    Content="{Binding [Prompt_Ok], Source={x:Static loc:LocalizationManager.Instance}}" />
        </StackPanel>
    </StackPanel>
</Window>
