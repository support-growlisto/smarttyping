<Window x:Class="SmartTyping.UI.Views.QuickPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:SmartTyping.UI.Localization"
        Width="540" Height="400" WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Topmost="True" ShowInTaskbar="False"
        AllowsTransparency="True" Background="Transparent"
        FontFamily="Segoe UI" FontSize="13">
    <Border Background="White" CornerRadius="10" BorderBrush="#CCC" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.3" />
        </Border.Effect>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox" Grid.Row="0" Padding="8,6" FontSize="15"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                     BorderBrush="#DDD" BorderThickness="0,0,0,1" />

            <ListBox x:Name="ResultList" Grid.Row="1" Margin="0,8,0,0" BorderThickness="0"
                     ItemsSource="{Binding Results}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnItemDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,3">
                            <TextBlock Text="{Binding Trigger}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Preview}" Foreground="#888" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="2" Margin="2,8,0,0" Foreground="#AAA" FontSize="11"
                       Text="{Binding [Picker_Hint], Source={x:Static loc:LocalizationManager.Instance}}" />
        </Grid>
    </Border>
</Window>
