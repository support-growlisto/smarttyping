<Window x:Class="SmartTyping.UI.Views.HotkeyRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:SmartTyping.UI.Localization"
        Title="{Binding [Settings_Change], Source={x:Static loc:LocalizationManager.Instance}}"
        Width="340" Height="150" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" FontFamily="Segoe UI" FontSize="14"
        Background="{DynamicResource Brush.Window}" Foreground="{DynamicResource Brush.Foreground}">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                       Text="{Binding [Hotkey_Prompt], Source={x:Static loc:LocalizationManager.Instance}}" />
            <TextBlock x:Name="Preview" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold"
                       Margin="0,14,0,0" Foreground="{DynamicResource Brush.Accent}" />
            <TextBlock HorizontalAlignment="Center" Margin="0,12,0,0" FontSize="11"
                       Foreground="{DynamicResource Brush.FaintForeground}"
                       Text="Esc" />
        </StackPanel>
    </Grid>
</Window>
